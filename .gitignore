# Vendored BMAD framework (third-party tooling; not this project's source)
_bmad/
.claude/
.agents/

# Privacy boundary (AD-5): private outputs live OUTSIDE the repo tree
# (~/.build-ledger/private/). Any in-tree private/ is additionally ignored as defense-in-depth,
# along with any local-only redaction denylist that ever lands here by accident.
private/
**/private/
redaction-denylist.yml
mirror.json

# Logs / scratch
*.log

# Node / Astro (site/)
node_modules/
dist/
.astro/
.wrangler/

# Generated copies of the canonical public/build-ledger.json (synced at build time)
site/src/data/build-ledger.json
site/public/build-ledger.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/

# OS / editor
.DS_Store
.idea/
.vscode/
.gstack/
