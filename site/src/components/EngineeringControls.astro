---
import type { Stats } from '../lib/ledger';
import { int } from '../lib/format';
const { stats } = Astro.props as { stats: Stats };
const a = stats.arts;
// Which artefact classes actually have data this snapshot vs. schema-tracked-but-absent.
const present = [
  a.wi > 0 && `${int(a.wi)} workflow-infrastructure`,
].filter(Boolean) as string[];
const absent = [a.da === 0 && 'delivery', a.qc === 0 && 'quality-control'].filter(Boolean) as string[];
---
<div class="controls-grid">
  <div class="stat-row">
    <div class="stat">
      <p class="label">Tests</p>
      <div class="numeral md">{int(stats.withTests)}<span class="denom">/{int(stats.repoCount)}</span></div>
      <p class="foot">repositories with a test suite</p>
    </div>
    <div class="stat">
      <p class="label">CI</p>
      <div class="numeral md">{int(stats.withCI)}<span class="denom">/{int(stats.repoCount)}</span></div>
      <p class="foot">continuous integration</p>
    </div>
    <div class="stat">
      <p class="label">Migrations</p>
      <div class="numeral md">{int(stats.withMig)}<span class="denom">/{int(stats.repoCount)}</span></div>
      <p class="foot">managed schema migrations</p>
    </div>
    <div class="stat">
      <p class="label">Files tracked</p>
      <div class="numeral md">{int(stats.filesTotal)}</div>
      <p class="foot">vendored &amp; generated excluded</p>
    </div>
  </div>

  <div class="artefacts">
    <p class="label">AI-native artefacts detected</p>
    <div class="arte-headline"><span class="numeral lg">{int(stats.artTotal)}</span> <span>workflow-infrastructure artefacts across <b>{int(stats.reposWithArtefacts)}</b> repositories</span></div>
    <p class="arte-note">Agent instructions, MCP tooling and orchestration — <code>CLAUDE.md</code>, <code>AGENTS.md</code>, <code>.cursorrules</code>, <code>.claude/</code>, <code>mcp</code> — each detected once.</p>
    {absent.length > 0 && (
      <p class="arte-absent">Schema tracks {absent.join(' and ')} artefacts separately; none detected in this snapshot.</p>
    )}
  </div>
</div>
