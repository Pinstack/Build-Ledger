---
import type { Ledger, Stats } from '../lib/ledger';
import { int, longDate } from '../lib/format';
const { ledger, stats } = Astro.props as { ledger: Ledger; stats: Stats };
const co = stats.co;
const m = ledger.ledger_metadata;
---
<div class="hero-band">
  <div class="wrap">
    <p class="hero-kicker">Build Ledger</p>
    <h1 class="hero-h1">AI-assisted engineering, evidenced in git.</h1>

    <dl class="hero-facts">
      <div><dt class="numeral">{int(co.total_commits)}</dt><dd>commits</dd></div>
      <div><dt class="numeral">{int(stats.repoCount)}</dt><dd>repositories <span class="dim">· {int(stats.publicCount)} public · {int(stats.privateCount)} private</span></dd></div>
      <div><dt class="numeral">{int(co.ai_coauthored_commits)}</dt><dd>commits explicitly co-authored with AI agents</dd></div>
    </dl>

    <p class="hero-punch">Not a claim. A ledger.</p>
    <p class="hero-lede">Generated from real repository history, with private work redacted and every headline reconciled to source data.</p>

    <div class="hero-meta">
      <span><span class="k">generated</span> {longDate(m.generated_at)}</span>
      <span><span class="k">identity</span> {m.identities_included.join(', ')}</span>
      <span><span class="k">schema</span> {m.schema_version}</span>
      <span><span class="k">source</span> <a href={m.data_url}>build-ledger.json</a></span>
    </div>
  </div>
</div>
