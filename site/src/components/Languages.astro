---
import type { Ledger } from '../lib/ledger';
import { pct } from '../lib/format';
const { ledger } = Astro.props as { ledger: Ledger };
const langs = ledger.aggregates.languages;
const max = Math.max(0.0001, ...langs.map((l) => l.share));
---
<div class="card-grid" style="grid-template-columns:1fr;">
  {langs.map((l) => (
    <div style="display:flex; align-items:center; gap:12px;">
      <span class="label" style="width:108px; margin:0;">{l.name}</span>
      <span style="flex:1; height:10px; background:var(--accent-soft); border-radius:4px; overflow:hidden;">
        <span style={`display:block; height:100%; width:${((l.share / max) * 100).toFixed(1)}%; background:var(--accent);`}></span>
      </span>
      <span class="sub" style="width:52px; text-align:right;">{pct(l.share)}</span>
    </div>
  ))}
</div>
<p class="sub" style="margin-top:10px">Share = fraction of repositories whose primary language is each (controlled-vocabulary labels only).</p>
