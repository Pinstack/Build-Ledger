---
import type { Ledger } from '../lib/ledger';
import { int, compact } from '../lib/format';
const { ledger } = Astro.props as { ledger: Ledger };
const rc = ledger.aggregates.repo_counts;
const t = ledger.aggregates.totals;
const repos = ledger.repositories;
const withTests = repos.filter((r) => r.signals.has_tests).length;
const withCI = repos.filter((r) => r.signals.has_ci).length;
const withMig = repos.filter((r) => r.signals.has_migrations).length;
const files = repos.reduce((a, r) => a + r.metrics.files, 0);
const total = repos.length;
---
<div class="card-grid">
  <div class="card">
    <p class="label">Repositories</p>
    <div class="numeral lg">{int(total)}</div>
    <p class="sub">{int(rc.public)} public · {int(rc.private)} private · {int(rc.archived)} archived</p>
  </div>
  <div class="card">
    <p class="label">User-authored commits</p>
    <div class="numeral lg">{int(t.user_authored_commits)}</div>
    <p class="sub">of {int(t.commits)} total commits</p>
  </div>
  <div class="card">
    <p class="label">Repos with tests</p>
    <div class="numeral lg">{int(withTests)}</div>
    <p class="sub">{int(withCI)} with CI · {int(withMig)} with migrations</p>
  </div>
  <div class="card">
    <p class="label">Files tracked</p>
    <div class="numeral lg">{int(files)}</div>
    <p class="sub">vendored / generated / lockfiles excluded</p>
  </div>
  <div class="card">
    <p class="label">Net LOC <span class="sub">(supporting cast)</span></p>
    <div class="numeral md">{t.loc_net ? compact(t.loc_net) : '—'}</div>
    <p class="sub">{t.loc_net ? 'added − removed, exclusions applied' : 'populated on a full local run'}</p>
  </div>
  <div class="card">
    <p class="label">Active repositories</p>
    <div class="numeral lg">{int(rc.active)}</div>
    <p class="sub">not archived</p>
  </div>
</div>
