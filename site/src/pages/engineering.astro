---
import '../styles/global.css';
import { loadLedger, deriveStats, SUPPORTED_MAJOR } from '../lib/ledger';
import Hero from '../components/Hero.astro';
import EvidenceCards from '../components/EvidenceCards.astro';
import WhatThisProves from '../components/WhatThisProves.astro';
import RepoTable from '../components/RepoTable.astro';
import EngineeringControls from '../components/EngineeringControls.astro';
import AgenticPractice from '../components/AgenticPractice.astro';
import Activity from '../components/Activity.astro';
import Methodology from '../components/Methodology.astro';

const res = loadLedger();
const stats = res.ok ? deriveStats(res.ledger) : null;
const activity = res.ok && res.ledger.activity.available;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Build Ledger — AI-assisted engineering, evidenced in git</title>
    <meta name="description" content="A git-backed ledger of sustained AI-assisted engineering. Generated from real repository history, private work redacted, every headline reconciled to source data." />
    <meta name="color-scheme" content="light" />
  </head>
  <body>
    {res.ok && stats ? (
      <>
        <Hero ledger={res.ledger} stats={stats} />

        <div class="wrap evidence">
          <EvidenceCards stats={stats} />
        </div>

        <main class="wrap">
          <section>
            <div class="section-head"><span class="idx">01</span>
              <div><h2>What this proves</h2><p class="thesis">Activity, AI attribution, and engineering controls are separated so the claim can be inspected rather than trusted.</p></div>
            </div>
            <WhatThisProves ledger={res.ledger} stats={stats} />
          </section>

          <section>
            <div class="section-head"><span class="idx">02</span>
              <div><h2>Repository evidence</h2><p class="thesis">Each repo shows its real GitHub visibility. Material work is named — public or private — while client-identifying repos stay silhouettes.</p></div>
            </div>
            <RepoTable ledger={res.ledger} stats={stats} />
          </section>

          {stats.practice.available && (
            <section>
              <div class="section-head"><span class="idx">03</span>
                <div><h2>Agentic practice</h2><p class="thesis">The work was built across logged Claude Code and Codex sessions — direct evidence of AI authorship beyond git trailers.</p></div>
              </div>
              <AgenticPractice stats={stats} />
            </section>
          )}

          <section>
            <div class="section-head"><span class="idx">{stats.practice.available ? '04' : '03'}</span>
              <div><h2>Engineering controls</h2><p class="thesis">Tests, CI, migrations, and the AI-native artefacts that make the workflow itself inspectable.</p></div>
            </div>
            <EngineeringControls stats={stats} />
          </section>

          {activity && (
            <section>
              <div class="section-head"><span class="idx">{stats.practice.available ? '05' : '04'}</span>
                <div><h2>Activity over time</h2><p class="thesis">Commit cadence from git history — shown as evidence of sustained work, not a productivity score, and reconciled against tests, CI, migrations and artefacts.</p></div>
              </div>
              <Activity ledger={res.ledger} />
            </section>
          )}

          <section style="border-bottom:none;">
            <div class="section-head"><span class="idx">{`0${3 + (stats.practice.available ? 1 : 0) + 1 + (activity ? 1 : 0)}`}</span>
              <div><h2>Methodology &amp; exclusions</h2><p class="thesis">How the figures are derived, what silhouettes hide, and what is deliberately excluded.</p></div>
            </div>
            <Methodology ledger={res.ledger} stats={stats} />
          </section>
        </main>

        <footer>
          <div class="wrap">
            <p>Build Ledger · {res.ledger.ledger_metadata.identities_included.join(', ')} · every figure is inspectable, or it doesn&rsquo;t ship.</p>
          </div>
        </footer>
      </>
    ) : (
      <main class="wrap" style="padding-top:64px;">
        <h1>Build Ledger</h1>
        <div class="empty" style="margin-top:20px;">
          <p class="label">Unsupported schema major</p>
          This page renders schema MAJOR {SUPPORTED_MAJOR} only. The file declares version <b>{res.ok ? '' : res.version}</b>.
          Refusing to render rather than mis-render (AD-7).
        </div>
      </main>
    )}
  </body>
</html>
